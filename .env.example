# Anthropic API key - haal op via https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Stripe keys - haal op via https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Prijs ID van je Stripe product (maak aan in Stripe dashboard)
STRIPE_PRICE_ID=price_...

# URL van je website (bijv. https://wozbezwaar.nl)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase (server-side; service_role key is GEHEIM)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# E-mailaflevering via Resend — OPTIONEEL.
# Laat leeg = de app mailt niet (klant ziet het bezwaar alleen op de site).
# Zodra RESEND_API_KEY + MAIL_FROM zijn ingevuld, mailt de app automatisch.
# Vereist: domein wozbezwaar.nl geverifieerd in Resend (DNS-records).
RESEND_API_KEY=re_...
MAIL_FROM=Bezwaar.WOZ <noreply@wozbezwaar.nl>
MAIL_REPLY_TO=support@wozbezwaar.nl
